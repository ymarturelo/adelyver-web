{
  "name": "adelyver-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "type": "module",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest --exclude '**/*.integration.test.ts' --exclude '**/*.integration.test.tsx'",
    "test:integration": "vitest --config vitest.integration.config.ts --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:status": "drizzle-kit status"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.1",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.27",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.3"
  }
}
